        # 移除 end_session_endpoint，讓 Dex 使用 Authentik 的 end-session
        # "end_session_endpoint": f"{base_url}/end-session",
        "jwks_uri": f"{base_url}/.well-known/jwks.json",
        "response_types_supported": ["code"],
        "subject_types_supported": ["public"],
        "id_token_signing_alg_values_supported": ["RS256"],
        "scopes_supported": ["openid", "profile", "email"]
    })

@app.route('/authorize', methods=['GET'])
def authorize():
    """OIDC 授權端點"""
    client_id = request.args.get('client_id')
    redirect_uri = request.args.get('redirect_uri')
    scope = request.args.get('scope', 'openid profile email')
    state = request.args.get('state')
    
    if not client_id or not redirect_uri:
        return jsonify({"error": "invalid_request"}), 400
    
    # 檢查是否已登錄
    if 'user_email' not in session:
        # 顯示登錄頁面
        return f'''
        <!DOCTYPE html>
        <html>
        <head><title>Kubeflow Auth Proxy - Login</title></head>
        <body>
            <h2>Kubeflow 登錄</h2>
            <form method="POST" action="/login">
                <input type="hidden" name="client_id" value="{client_id}">
                <input type="hidden" name="redirect_uri" value="{redirect_uri}">
                <input type="hidden" name="scope" value="{scope}">
                <input type="hidden" name="state" value="{state}">
                <p>
                    <label>Email:</label><br>
                    <input type="email" name="email" required>
                </p>
                <p>
                    <label>Password:</label><br>
                    <input type="password" name="password" required>
                </p>
                <p><button type="submit">登錄</button></p>
            </form>
        </body>
        </html>
        '''
    
    # 已登錄，生成授權碼
    auth_code = secrets.token_urlsafe(32)
    auth_codes_storage[auth_code] = {
        'client_id': client_id,
        'redirect_uri': redirect_uri,
        'scope': scope,
        'user_email': session['user_email'],
        'expires_at': datetime.now() + timedelta(minutes=10)
    }
    
    redirect_url = f"{redirect_uri}?code={auth_code}&state={state}"
    return redirect(redirect_url)

@app.route('/login', methods=['POST'])
def login():
    """處理登錄請求"""
    email = request.form.get('email')
    password = request.form.get('password')
    client_id = request.form.get('client_id')
    redirect_uri = request.form.get('redirect_uri')
    scope = request.form.get('scope')
    state = request.form.get('state')
    
    if not email or not password:
        return jsonify({"error": "invalid_request"}), 400
    
    # 從 MySQL 獲取用戶
    user = get_user_from_mysql(email)
    if not user:
        return "Invalid email or password", 401
    
    # 驗證 bcrypt 密碼
    if not verify_bcrypt_password(password, user['password_hash']):
        return "Invalid email or password", 401
    
    # 登錄成功，保存到 session
    session['user_email'] = user['email']
    session['user_name'] = user['name']
    session['user_role'] = user['role']
    
    # 生成授權碼
    auth_code = secrets.token_urlsafe(32)
    auth_codes_storage[auth_code] = {
        'client_id': client_id,
        'redirect_uri': redirect_uri,
        'scope': scope,
        'user_email': user['email'],
        'expires_at': datetime.now() + timedelta(minutes=10)
    }
    
    redirect_url = f"{redirect_uri}?code={auth_code}&state={state}"
    return redirect(redirect_url)

@app.route('/token', methods=['POST'])
def token():
    """OIDC Token 端點"""
    grant_type = request.form.get('grant_type')
    code = request.form.get('code')
    client_id = request.form.get('client_id')
    client_secret = request.form.get('client_secret')
    redirect_uri = request.form.get('redirect_uri')
    
    if grant_type != 'authorization_code':
        return jsonify({"error": "unsupported_grant_type"}), 400
    
    # 驗證授權碼（從服務器端存儲讀取）
    if code not in auth_codes_storage:
        logger.warning(f"授權碼不存在: {code}")
        return jsonify({"error": "invalid_grant"}), 400
    
    auth_info = auth_codes_storage[code]
    
    # 檢查過期
    if datetime.now() > auth_info['expires_at']:
        del auth_codes_storage[code]
        logger.warning(f"授權碼已過期: {code}")
        return jsonify({"error": "invalid_grant"}), 400
    
    # 驗證 client_id 和 redirect_uri
    if auth_info['client_id'] != client_id or auth_info['redirect_uri'] != redirect_uri:
        return jsonify({"error": "invalid_client"}), 400
    
    # 生成 access token 和 id token
    user_email = auth_info['user_email']
    user = get_user_from_mysql(user_email)
    
    # 從 LDAP 獲取用戶信息（補充組信息等）
    ldap_info = get_user_info_from_ldap(user_email)
    if ldap_info:
        # 合併 LDAP 信息
        user['name'] = ldap_info.get('name', user['name'])
        user['ldap_role'] = ldap_info.get('role')
    
    now = datetime.utcnow()
    
    # 使用 RS256 算法簽名 JWT
    private_key_pem = _private_key.private_bytes(
        encoding=serialization.Encoding.PEM,
        format=serialization.PrivateFormat.PKCS8,
        encryption_algorithm=serialization.NoEncryption()
    )
    
    access_token = jwt.encode({
        'sub': user_email,
        'email': user_email,
        'name': user['name'],
        'iat': now,
        'exp': now + timedelta(hours=1)
    }, private_key_pem, algorithm='RS256')
    
    id_token = jwt.encode({
        'iss': OIDC_ISSUER,
        'sub': user_email,
        'aud': client_id,
        'email': user_email,
        'name': user['name'],
        'iat': now,
        'exp': now + timedelta(hours=1)
    }, private_key_pem, algorithm='RS256')
    
    # 刪除已使用的授權碼
    del auth_codes_storage[code]
    
    return jsonify({
        "access_token": access_token,
        "token_type": "Bearer",
        "expires_in": 3600,
        "id_token": id_token
    })

@app.route('/userinfo', methods=['GET'])
def userinfo():
    """OIDC UserInfo 端點"""
    auth_header = request.headers.get('Authorization')
    if not auth_header or not auth_header.startswith('Bearer '):
        return jsonify({"error": "invalid_token"}), 401
    
    token = auth_header.split(' ')[1]
    try:
        # 使用公鑰驗證 RS256 JWT
        public_key_pem = _public_key.public_bytes(
            encoding=serialization.Encoding.PEM,
            format=serialization.PublicFormat.SubjectPublicKeyInfo
        )
        payload = jwt.decode(token, public_key_pem, algorithms=['RS256'])
        user_email = payload.get('email')
        user = get_user_from_mysql(user_email)
        
        if not user:
            return jsonify({"error": "user_not_found"}), 404
        
        # 從 LDAP 獲取補充信息
        ldap_info = get_user_info_from_ldap(user_email)
        response = {
            "sub": user_email,
            "email": user_email,
            "name": user['name'],
            "preferred_username": user_email
        }
        
        # 如果有 LDAP 信息，添加組信息
        if ldap_info and ldap_info.get('role'):
            response['groups'] = [ldap_info['role']]
        
        return jsonify(response)
    except jwt.InvalidTokenError:
        return jsonify({"error": "invalid_token"}), 401

@app.route('/.well-known/jwks.json', methods=['GET'])
def jwks():
    """JWKS 端點 - 提供公鑰用於驗證 JWT"""
    # 從公鑰生成 JWK
    public_key_pem = _public_key.public_bytes(
        encoding=serialization.Encoding.PEM,
        format=serialization.PublicFormat.SubjectPublicKeyInfo
    )
    
    # 提取 RSA 公鑰的模數和指數
    public_numbers = _public_key.public_numbers()
    
    # 將整數轉換為 base64url 編碼的字符串
    def int_to_base64url(n):
        # 將整數轉換為字節
        byte_length = (n.bit_length() + 7) // 8
        n_bytes = n.to_bytes(byte_length, byteorder='big')
        # Base64URL 編碼
        return base64.urlsafe_b64encode(n_bytes).decode('utf-8').rstrip('=')
    
    jwk = {
        "kty": "RSA",
        "use": "sig",
        "alg": "RS256",
        "kid": "auth-proxy-key-1",
        "n": int_to_base64url(public_numbers.n),
        "e": int_to_base64url(public_numbers.e)
    }
    
    return jsonify({
        "keys": [jwk]
    })

@app.route('/end-session', methods=['GET', 'POST'])
def end_session():
    """OIDC End Session 端點（登出）"""
    # 清除 session
    session.clear()
    
    # 獲取 redirect_uri 參數（如果有的話）
    post_logout_redirect_uri = request.args.get('post_logout_redirect_uri') or request.form.get('post_logout_redirect_uri')
    
    if post_logout_redirect_uri:
        # 如果有重定向 URI，重定向到該 URI
        return redirect(post_logout_redirect_uri)
    else:
        # 否則返回成功消息
        return jsonify({"status": "logged_out"}), 200

