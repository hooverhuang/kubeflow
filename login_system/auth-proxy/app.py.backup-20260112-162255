# LDAP 配置（用於查詢用戶信息和組）
LDAP_SERVER = os.getenv("LDAP_SERVER", "openldap.auth.svc.cluster.local")
LDAP_PORT = int(os.getenv("LDAP_PORT", "389"))
LDAP_BASE_DN = os.getenv("LDAP_BASE_DN", "dc=ubilink,dc=ai")
LDAP_ADMIN_DN = os.getenv("LDAP_ADMIN_DN", f"cn=admin,{LDAP_BASE_DN}")
LDAP_ADMIN_PASSWORD = os.getenv("LDAP_ADMIN_PASSWORD", "admin123")
LDAP_USERS_OU = f"ou=users,{LDAP_BASE_DN}"

def get_user_from_mysql(email):
    """從 MySQL 獲取用戶信息"""
    try:
        conn = pymysql.connect(
            host=MYSQL_HOST,
            port=MYSQL_PORT,
            user=MYSQL_USER,
            password=MYSQL_PASSWORD,
            database=MYSQL_DB,
            charset='utf8mb4'
        )
        cursor = conn.cursor()
        cursor.execute(
            "SELECT email, password, name, role FROM users WHERE email = %s AND status = 'active'",
            (email,)
        )
        row = cursor.fetchone()
        cursor.close()
        conn.close()
        
        if row:
            return {
                "email": row[0],
                "password_hash": row[1],
                "name": row[2] or row[0],
                "role": row[3] or "user"
            }
        return None
    except Exception as e:
        logger.error(f"MySQL 查詢錯誤: {e}")
        return None

def verify_bcrypt_password(password, password_hash):
    """驗證 bcrypt 密碼"""
    try:
        if not password_hash or not password_hash.startswith("$2"):
            return False
        return bcrypt.checkpw(password.encode('utf-8'), password_hash.encode('utf-8'))
    except Exception as e:
        logger.error(f"密碼驗證錯誤: {e}")
        return False

def get_user_info_from_ldap(email):
    """從 LDAP 獲取用戶信息和組"""
    try:
        server = Server(LDAP_SERVER, port=LDAP_PORT, get_info=ALL)
        with Connection(server, LDAP_ADMIN_DN, LDAP_ADMIN_PASSWORD, auto_bind=True) as conn:
            user_dn = f"uid={email},{LDAP_USERS_OU}"
            if conn.search(user_dn, '(objectClass=*)', attributes=['cn', 'mail', 'description']):
                entry = conn.entries[0]
                return {
                    "name": str(entry.cn[0]) if 'cn' in entry else email,
                    "email": str(entry.mail[0]) if 'mail' in entry else email,
                    "role": str(entry.description[0]) if 'description' in entry else None
                }
        return None
    except Exception as e:
        logger.warning(f"LDAP 查詢錯誤（將使用 MySQL 數據）: {e}")
        return None

