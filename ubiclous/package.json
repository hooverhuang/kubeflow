{
  "name": "kubeflow-ui",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "server": "node server/index.js",
    "dev": "concurrently -e \"[server]\" \"npm run server\" \"npm run client\"",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "install:all": "npm install && cd client && npm install"
  },
  "dependencies": {
    "@kubernetes/client-node": "^0.21.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "axios": "^1.6.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
